# hottam 프론트엔드 (CF Pages, 정적 export) — 빌드 시점에만 사용
# 실제 시크릿은 hottam-api Worker에 저장 (wrangler secret put)

# Public — 빌드 결과물(JS bundle)에 그대로 박힘. 시크릿 절대 넣지 말 것.
NEXT_PUBLIC_API_URL="https://hottam-api.j-810.workers.dev"

# 아래는 더 이상 프론트엔드에서 사용하지 않음.
# 모두 hottam-api Worker secret으로 이동:
#   YOUTUBE_API_KEY (필수)
#   GEMINI_API_KEY (옵션, /remake 무료)
#   ANTHROPIC_API_KEY (옵션, /remake 유료)
# 등록: cd ~/hottam-api && echo "<KEY>" | npx wrangler secret put <NAME>
